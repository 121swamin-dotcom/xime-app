# ── Supabase / Postgres ──────────────────────────────────────────────────────
# Get this from: Supabase Dashboard → Project Settings → Database → Connection string
# Use the "URI" format (Transaction pooler recommended for Render free tier)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_byte_hex_secret

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── Email (Gmail SMTP) ───────────────────────────────────────────────────────
# Use a Gmail App Password (not your main password)
# Gmail → Manage Google Account → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=swaminathann@xime.org
SMTP_PASS=replace_with_gmail_app_password
EMAIL_FROM="Prof Swaminathan N <swaminathann@xime.org>"
ADMIN_EMAIL=swaminathann@xime.org

# ── App Base URL (used in tokenised email links) ─────────────────────────────
API_BASE_URL=http://localhost:3001
